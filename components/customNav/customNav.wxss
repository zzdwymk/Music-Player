.custom-nav {
  position: fixed;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  z-index: 9999;
}

.back-btn {
  width: 0rpx;
}

.back-btn image {
  width: 0rpx;
}

.nav-title {
  flex: 1;
  width: 100%;
  text-align: center;
  font-size: 35rpx;
  font-weight: 500;
  height: 15rpx;
  font-family: '华文行楷', '华文新魏', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif
}

.nav-right {
  width: 0rpx;
}