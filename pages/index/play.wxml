<!-- 播放器 -->
<view class="content-play" catchtap="closePlayModeMenu" style="color:{{contrastColor}};">
  <!-- 显示音乐信息 -->
  <view class="content-play-info" style="color:{{contrastColor}};">
    <text style="color:{{contrastColor}};">{{play.title}}</text>
    <view style="color:{{contrastColor}};">—— {{play.singer}} ——</view>
  </view>
  <!-- 显示专辑封面 -->
  <view class="content-play-cover">
    <view class="vinyl-record"></view>
    <image src="{{play.coverImgUrl}}" style="animation-play-state:{{state}}" />
  </view>

  <!-- 隐藏取色用的画布 必须存在 -->
<canvas type="2d" id="colorCanvas" style="width:0;height:0;position:fixed;z-index:-999;"></canvas>

  <!-- 歌词区域 -->
  <scroll-view wx:if="{{showLyric}}"
    scroll-y
    scroll-x
    scroll-top="{{scrollTop}}"
    scroll-left="{{scrollLeft}}"
    style="height:250px; text-align:center; font-family: 'Times New Roman', Times, serif; overflow-x: auto;"
    scroll-with-animation
    catchtap="preventBubble"
  >
    <view wx:for="{{lyricList}}" wx:key="time"
      style="height:{{lineHeight}}px; line-height:{{lineHeight}}px; color:{{currentIndex===index ? contrastColor : lyricDimColor}}; font-size:{{currentIndex===index ? '38rpx' : '32rpx'}}; font-weight:{{currentIndex===index ? 'bold' : 'normal'}};"
      class="lyric-item {{currentIndex===index ? 'active' : ''}}"
    >
      <text wx:for="{{item.parts}}" wx:for-item="part" wx:key="{{$index}}" class="{{part.isChinese ? 'lyric-cn' : 'lyric-en'}}">{{part.text}}</text>
    </view>
  </scroll-view>
  <!-- 显示播放进度和时间 -->
  <view class="content-play-progress" style="color:{{contrastColor}};">
    <text style="color:{{contrastColor}};">{{play.currentTime}}</text>
    <view>
      <slider bindchange="sliderChange" activeColor="{{contrastColor}}" block-size="12" backgroundColor="{{lyricDimColor}}" value="{{play.percent}}" />
    </view>
    <text style="color:{{contrastColor}};">{{play.duration}}</text>
  </view>

  <!-- 播放器页面专用底部播放器 -->
  <view class="player-page-controls">
    <!-- 进度条 -->
    <view class="player-progress-bar">
      <view class="player-progress-fill" style="width: {{play.percent}}%;"></view>
    </view>
    <!-- 播放模式按钮 -->
    <view class="play-mode-btn {{showPlayModeMenu ? 'active' : ''}}" catchtap="togglePlayModeMenu">
      <image src="/images/{{playModeIcon}}.svg" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
    </view>
    <!-- 播放模式下拉菜单 -->
    <view class="play-mode-menu {{showPlayModeMenu ? 'show' : ''}}" style="background-color: {{bgMainColor}};">
      <view class="play-mode-item {{playMode === 'sequence' ? 'active' : ''}}" catchtap="selectPlayMode" data-mode="sequence">
        <image src="/images/顺序播放.svg" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
        <text style="color:{{contrastColor}};">顺序播放</text>
      </view>
      <view class="play-mode-item {{playMode === 'random' ? 'active' : ''}}" catchtap="selectPlayMode" data-mode="random">
        <image src="/images/随机播放.svg" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
        <text style="color:{{contrastColor}};">随机播放</text>
      </view>
      <view class="play-mode-item {{playMode === 'single' ? 'active' : ''}}" catchtap="selectPlayMode" data-mode="single">
        <image src="/images/单曲循环.svg" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
        <text style="color:{{contrastColor}};">单曲循环</text>
      </view>
    </view>
    <!-- 上一首 -->
    <view class="control-btn" catchtap="prev" hover-class="control-btn-hover">
      <image class="prev-btn" src="/images/icon_下一首.svg" catchtap="prev" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
    </view>
    <!-- 播放或暂停 -->
    <view class="control-btn" catchtap="play">
      <image class="play-btn" wx:if="{{state=='paused'}}" src="/images/播放.svg" catchtap="play" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
      <image class="play-btn" wx:else src="/images/暂停.svg" catchtap="pause" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
    </view>
    <!-- 下一首 -->
    <view class="control-btn" catchtap="next" hover-class="control-btn-hover">
      <image class="next-btn" src="/images/icon_下一首.svg" catchtap="next" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
    </view>
    <!-- 歌词切换 -->
    <view class="lyric-toggle-btn {{showLyric ? 'active' : ''}}" catchtap="toggleLyric">
      <image src="/images/歌词.svg" style="filter:{{contrastColor === '#ffffff' ? 'brightness(0) invert(1)' : 'none'}};" />
    </view>
  </view>
</view>